{
  "manifest_schema_version": 3,
  "sdk_version": "5.0.0",
  "app_id": "web-tools",
  "version": "1.4.3",
  "name": "Web Tools",
  "description": "Domain health monitoring — DNS, SSL, HTTP headers grade, blacklist 30 DNSBL, WHOIS, SEO, email SPF/DMARC/DKIM, geo probes from 4 regions, port scans, SMTP test, recurring automated monitors with alerts.",
  "icon": "icon.svg",
  "actions_explicit": true,
  "system": false,
  "capabilities": [
    "store:read",
    "store:write"
  ],
  "tools": [
    {
      "name": "skeleton_refresh_web_tools",
      "description": "Refresh web-tools monitor statuses from last scan snapshots. Provides instant Webbee context: how many monitors are critical/warning.",
      "scopes": [],
      "parameters": {}
    },
    {
      "name": "dns_lookup",
      "description": "DNS record lookup — A/AAAA/MX/NS/TXT/CNAME/SRV/DNSSEC, global propagation across 15+ resolvers, direct authoritative NS query. Use for any DNS question.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "DNS lookup parameters.",
        "properties": {
          "domain": {
            "title": "Domain",
            "type": "string"
          },
          "record_type": {
            "default": "A",
            "enum": [
              "A",
              "AAAA",
              "IP",
              "MX",
              "NS",
              "TXT",
              "CNAME",
              "SRV",
              "DNSSEC",
              "all",
              "propagation"
            ],
            "title": "Record Type",
            "type": "string"
          },
          "authoritative": {
            "default": false,
            "description": "Query from domain's own authoritative NS (A/AAAA/MX/NS/TXT/CNAME)",
            "title": "Authoritative",
            "type": "boolean"
          },
          "propagation_type": {
            "default": "A",
            "description": "Record type for propagation check",
            "enum": [
              "A",
              "MX",
              "NS",
              "TXT",
              "CNAME"
            ],
            "title": "Propagation Type",
            "type": "string"
          }
        },
        "required": [
          "domain"
        ],
        "title": "DnsLookupParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "ssl_check",
      "description": "SSL/TLS certificate — expiry date, days remaining, issuer, grade A-F. Full mode adds chain, SANs, fingerprint and TLS version support.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "SSL certificate check parameters.",
        "properties": {
          "domain": {
            "title": "Domain",
            "type": "string"
          },
          "full": {
            "default": false,
            "description": "Full check — adds chain, SANs, fingerprint, TLS version support",
            "title": "Full",
            "type": "boolean"
          },
          "port": {
            "default": 443,
            "title": "Port",
            "type": "integer"
          }
        },
        "required": [
          "domain"
        ],
        "title": "SslCheckParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "whois_lookup",
      "description": "WHOIS for domain (registrar, dates, nameservers, status) or IP (ASN, org, country). Use detail= for targeted sections: quick/full/dates/registrar/availability.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "WHOIS lookup parameters.",
        "properties": {
          "target": {
            "description": "Domain name or IP address",
            "title": "Target",
            "type": "string"
          },
          "target_type": {
            "default": "domain",
            "enum": [
              "domain",
              "ip"
            ],
            "title": "Target Type",
            "type": "string"
          },
          "detail": {
            "default": "quick",
            "description": "'quick' — key fields, 'full' — complete, 'dates'/'registrar'/'availability' — specific section",
            "enum": [
              "full",
              "quick",
              "dates",
              "registrar",
              "availability"
            ],
            "title": "Detail",
            "type": "string"
          }
        },
        "required": [
          "target"
        ],
        "title": "WhoisParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "http_check",
      "description": "HTTP security headers grade A+ to F (HSTS/CSP/X-Frame-Options/X-Content-Type-Options). Shows missing headers with fix tips, redirect chain, response time.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "HTTP analysis parameters.",
        "properties": {
          "domain": {
            "title": "Domain",
            "type": "string"
          },
          "check_type": {
            "default": "grade",
            "description": "headers=full analysis, grade=score only, quick=grade+counts, missing=broken headers+fixes, status, redirects",
            "enum": [
              "headers",
              "grade",
              "quick",
              "missing",
              "status",
              "status_quick",
              "redirects"
            ],
            "title": "Check Type",
            "type": "string"
          },
          "mode": {
            "default": "standard",
            "description": "standard=6 headers, strict=8 headers",
            "enum": [
              "standard",
              "strict"
            ],
            "title": "Mode",
            "type": "string"
          }
        },
        "required": [
          "domain"
        ],
        "title": "HttpCheckParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "network_check",
      "description": "Network diagnostics — ICMP ping (RTT/loss), MTR traceroute per-hop, reverse DNS (PTR), IP geolocation + ASN, ASN WHOIS prefix list.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Network diagnostic parameters.",
        "properties": {
          "target": {
            "description": "Domain name or IP address",
            "title": "Target",
            "type": "string"
          },
          "check_type": {
            "default": "ping",
            "description": "ping=RTT/loss, traceroute=MTR per-hop, reverse_dns=PTR, ip_lookup=geo+ASN, asn=ASN WHOIS",
            "enum": [
              "ping",
              "traceroute",
              "reverse_dns",
              "ip_lookup",
              "ip_lookup_quick",
              "asn"
            ],
            "title": "Check Type",
            "type": "string"
          }
        },
        "required": [
          "target"
        ],
        "title": "NetworkCheckParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "seo_check",
      "description": "SEO check — meta title/description length and issues, robots.txt rules, sitemap.xml validation, Google indexing status. Use check_type to target a specific area.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "SEO check parameters.",
        "properties": {
          "target": {
            "description": "Domain or full URL (full URL for meta check)",
            "title": "Target",
            "type": "string"
          },
          "check_type": {
            "default": "meta",
            "description": "meta=title/description/issues, robots=robots.txt rules, sitemap=sitemap.xml, indexing=Google status",
            "enum": [
              "meta",
              "robots",
              "sitemap",
              "indexing"
            ],
            "title": "Check Type",
            "type": "string"
          }
        },
        "required": [
          "target"
        ],
        "title": "SeoCheckParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "email_check",
      "description": "Email authentication — SPF/DMARC/DKIM/BIMI checks or combined A-F grade, trace raw email headers to find originating IP, generate SPF or DMARC records.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Email infrastructure check parameters.",
        "properties": {
          "domain": {
            "title": "Domain",
            "type": "string"
          },
          "check_type": {
            "default": "full",
            "description": "spf/dmarc/dkim/bimi=individual check, full=grade A-F, trace=parse raw headers, generate_spf/generate_dmarc=build record",
            "enum": [
              "spf",
              "dmarc",
              "dkim",
              "bimi",
              "full",
              "trace",
              "generate_spf",
              "generate_dmarc"
            ],
            "title": "Check Type",
            "type": "string"
          },
          "dkim_selector": {
            "default": "google",
            "description": "DKIM selector (for 'dkim' check)",
            "title": "Dkim Selector",
            "type": "string"
          },
          "raw_headers": {
            "default": "",
            "description": "Raw Received: headers to parse (for 'trace')",
            "title": "Raw Headers",
            "type": "string"
          },
          "spf_includes": {
            "description": "SPF include domains (for 'generate_spf')",
            "items": {
              "type": "string"
            },
            "title": "Spf Includes",
            "type": "array"
          },
          "dmarc_policy": {
            "default": "quarantine",
            "description": "DMARC policy (for 'generate_dmarc')",
            "enum": [
              "none",
              "quarantine",
              "reject"
            ],
            "title": "Dmarc Policy",
            "type": "string"
          }
        },
        "required": [
          "domain"
        ],
        "title": "EmailCheckParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "blacklist_check",
      "description": "Spam blacklist check — IP against 30 DNSBL lists (Spamhaus, SpamCop, Barracuda) or domain against SURBL. Returns verdict: clean / listed / critical.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Blacklist check parameters.",
        "properties": {
          "target": {
            "description": "IPv4 address or domain name",
            "title": "Target",
            "type": "string"
          },
          "target_type": {
            "default": "ip",
            "description": "'ip' checks 30 DNSBL in parallel, 'domain' resolves to IP then checks SURBL",
            "enum": [
              "ip",
              "domain"
            ],
            "title": "Target Type",
            "type": "string"
          }
        },
        "required": [
          "target"
        ],
        "title": "BlacklistParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "port_scan",
      "description": "TCP port check — single port status (open/closed/filtered) or preset scan: web (80/443/8080/8443), mail (25/587/465/993/995), database (3306/5432/6379), all.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Port scan parameters.",
        "properties": {
          "host": {
            "title": "Host",
            "type": "string"
          },
          "port": {
            "default": 0,
            "description": "Specific port to check (0 = preset scan)",
            "title": "Port",
            "type": "integer"
          },
          "preset": {
            "default": "web",
            "description": "Port preset: web (80/443/8080/8443), mail (25/587/465/993/995), database (3306/5432/6379), all",
            "enum": [
              "web",
              "mail",
              "database",
              "all"
            ],
            "title": "Preset",
            "type": "string"
          }
        },
        "required": [
          "host"
        ],
        "title": "PortScanParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "smtp_test",
      "description": "SMTP server test — connects via MX record or direct host, verifies EHLO/STARTTLS/AUTH support, reads server banner. Use to diagnose email delivery problems.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "SMTP test parameters.",
        "properties": {
          "target": {
            "description": "Domain name (uses MX) or specific mail server hostname",
            "title": "Target",
            "type": "string"
          },
          "port": {
            "default": 0,
            "description": "Specific port to test (0 = auto-try 587/25/465 via MX)",
            "title": "Port",
            "type": "integer"
          }
        },
        "required": [
          "target"
        ],
        "title": "SmtpTestParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "geo_check",
      "description": "Multi-region probe from EU/US/SG/MD — DNS resolution + anycast mismatch, ping latency, HTTP availability, SSL validity, MTR traceroute, independently per region.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Multi-region geo probe parameters.",
        "properties": {
          "target": {
            "description": "Domain name or IP address",
            "title": "Target",
            "type": "string"
          },
          "check_type": {
            "default": "full",
            "description": "Probe from EU/US/SG/MD: dns=resolution+mismatch, ping=latency, http=status, ssl=validity, traceroute, full=dns+http+ssl",
            "enum": [
              "dns",
              "ping",
              "http",
              "ssl",
              "traceroute",
              "full"
            ],
            "title": "Check Type",
            "type": "string"
          },
          "dns_type": {
            "default": "A",
            "enum": [
              "A",
              "MX",
              "NS",
              "TXT",
              "CNAME"
            ],
            "title": "Dns Type",
            "type": "string"
          }
        },
        "required": [
          "target"
        ],
        "title": "GeoCheckParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "domain_full_check",
      "description": "Complete domain audit — runs DNS+SSL+WHOIS+HTTP+email+blacklist+geo in parallel in one call. Use when user asks for full site health, domain report or audit.",
      "action_type": "read",
      "chain_callable": true,
      "effects": [],
      "id_projection": "",
      "params_schema": {
        "description": "Full parallel domain audit parameters.",
        "properties": {
          "domain": {
            "title": "Domain",
            "type": "string"
          },
          "checks": {
            "default": [
              "dns",
              "ssl",
              "http",
              "email",
              "blacklist"
            ],
            "description": "Checks to run in parallel. Add 'geo' for multi-region probe (slowest). Add 'whois' for ownership data.",
            "items": {
              "enum": [
                "dns",
                "ssl",
                "whois",
                "http",
                "email",
                "blacklist",
                "geo"
              ],
              "type": "string"
            },
            "title": "Checks",
            "type": "array"
          }
        },
        "required": [
          "domain"
        ],
        "title": "DomainFullCheckParams",
        "type": "object"
      },
      "return_schema": {},
      "event": "",
      "background": false,
      "long_running": false,
      "scopes": [],
      "owner_chat_tool": "tool_web_tools_chat"
    },
    {
      "name": "create_domain_group",
